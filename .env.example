# 로컬 개발용 환경변수 템플릿.
# .env 가 없으면 컨테이너 기동 시 이 파일을 복사해 자동 생성한다.
# 아래 DB 값들은 docker-compose.yml 의 기본값과 반드시 동일해야 한다
# (달라지면 이미 초기화된 MySQL 볼륨의 계정과 어긋나 인증에 실패한다).
# 실제 배포에서는 이 파일이 아니라 호스팅 플랫폼의 secret 으로 주입한다.

DB_ROOT_PASSWORD=ai_health_root
DB_USER=ai_health_user
DB_PASSWORD=ai_health_password
DB_NAME=ai_health
# 호스트에서 직접 접속할 때 쓰는 값(= compose 가 노출하는 호스트 포트).
# 로컬 MySQL 과 충돌하지 않도록 3307 을 사용한다. 컨테이너 내부는 compose 가 mysql:3306 으로 덮어쓴다.
DB_HOST=localhost
DB_PORT=3307

# 로컬 전용 값 — 배포 시에는 반드시 긴 랜덤 문자열로 교체할 것.
JWT_SECRET_KEY=local-dev-only-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_COOKIE_SECURE=false
